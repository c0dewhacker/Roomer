    "@types/ldapjs": "^3.0.6",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.15",
    "pino-pretty": "^11.0.0",
    "prisma": "^5.14.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0"
