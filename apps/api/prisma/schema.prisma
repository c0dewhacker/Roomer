generator client {
  provider      = "prisma-client-js"
  // Include the Alpine/musl binary so the client works in node:alpine Docker images.
  // "native" covers local development on macOS/Linux glibc.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  LOCAL
  OIDC
  SAML
  LDAP
}

enum AuthConfigProvider {
  OIDC
  SAML
  LDAP
}

enum GlobalRole {
  SUPER_ADMIN
  USER
}

enum ResourceRoleType {
  BUILDING_ADMIN
  FLOOR_MANAGER
  USER
  VIEWER
}

enum ResourceScopeType {
  BUILDING
  FLOOR
}

enum AccountStatus {
  ACTIVE
  BLOCKED
}

/// Booking eligibility status for bookable assets (replaces DeskStatus).
enum BookableStatus {
  OPEN
  RESTRICTED
  ASSIGNED
  DISABLED
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum QueueEntryStatus {
  WAITING
  PROMOTED
  CLAIMED
  EXPIRED
  CANCELLED
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
  DISABLED
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_CANCELLED_BY_ADMIN
  BOOKING_REMINDER
  QUEUE_JOINED
  QUEUE_PROMOTED
  QUEUE_EXPIRED
  QUEUE_CLAIM_EXPIRING
  ASSET_ASSIGNED
  ASSET_DUE_RETURN
  WELCOME
  FLOOR_AVAILABLE
}

enum FloorPlanFileType {
  IMAGE
  PDF
  DXF
}

model AuthConfig {
  id        String             @id @default(cuid())
  provider  AuthConfigProvider @unique
  enabled   Boolean            @default(false)
  config    Json               @default("{}")
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model Organisation {
  id                          String      @id @default(cuid())
  name                        String
  slug                        String      @unique
  defaultBookingDurationHours Int         @default(8)
  maxAdvanceBookingDays       Int         @default(14)
  maxBookingsPerUser          Int         @default(5)
  queueClaimWindowHours       Int         @default(4)
  dateFormat                  String      @default("dd/MM/yyyy")
  branding                    Json        @default("{}")
  createdAt                   DateTime    @default(now())
  updatedAt                   DateTime    @updatedAt
  buildings                   Building[]
  groups                      UserGroup[]
}

model Building {
  id             String             @id @default(cuid())
  organisationId String
  name           String
  address        String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organisation   Organisation       @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  floors         Floor[]
  resourceRoles       UserResourceRole[]
  groupResourceRoles  GroupResourceRole[]
  leases              BuildingLease[]
  groupAccess         GroupBuildingAccess[]
}

model BuildingLease {
  id           String          @id @default(cuid())
  buildingId   String
  name         String
  startDate    DateTime
  endDate      DateTime?
  landlord     String?
  rentAmount   Float?
  currency     String          @default("GBP")
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  building     Building        @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  documents    LeaseDocument[]

  @@index([buildingId])
}

model LeaseDocument {
  id          String        @id @default(cuid())
  leaseId     String
  filename    String
  storagePath String
  mimeType    String        @default("application/octet-stream")
  sizeBytes   Int           @default(0)
  uploadedAt  DateTime      @default(now())
  lease       BuildingLease @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([leaseId])
}

model Floor {
  id         String             @id @default(cuid())
  buildingId String
  name       String
  level      Int                @default(0)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  building   Building           @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floorPlan  FloorPlan?
  zoneGroups ZoneGroup[]
  zones      Zone[]
  assets     Asset[]
  resourceRoles      UserResourceRole[]
  groupResourceRoles GroupResourceRole[]
  groupAccess        GroupFloorAccess[]
  subscriptions      FloorSubscription[]
}

model FloorPlan {
  id            String            @id @default(cuid())
  floorId       String            @unique
  fileType      FloorPlanFileType
  originalPath  String
  renderedPath  String
  thumbnailPath String?
  width         Int
  height        Int
  displayScale  Float             @default(1.0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  floor         Floor             @relation(fields: [floorId], references: [id], onDelete: Cascade)
}

model ZoneGroup {
  id        String   @id @default(cuid())
  floorId   String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  floor     Floor    @relation(fields: [floorId], references: [id], onDelete: Cascade)
  zones     Zone[]
}

model Zone {
  id          String     @id @default(cuid())
  floorId     String
  zoneGroupId String?
  name        String
  colour      String     @default("#6366f1")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  floor       Floor      @relation(fields: [floorId], references: [id], onDelete: Cascade)
  zoneGroup   ZoneGroup? @relation(fields: [zoneGroupId], references: [id])
  /// Assets whose primary zone is this zone
  assets      Asset[]    @relation("PrimaryZone")
  /// Additional zone memberships (asset can belong to multiple zones)
  assetZones  AssetZone[]
  subscriptionZones FloorSubscriptionZone[]
}

/// Junction table for additional zone memberships of an asset.
/// An asset's primary zone is stored as Asset.primaryZoneId.
model AssetZone {
  assetId   String
  zoneId    String
  createdAt DateTime @default(now())
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  zone      Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@id([assetId, zoneId])
  @@index([assetId])
  @@index([zoneId])
}

/// Per-asset allow-list: when an asset's bookingStatus is RESTRICTED,
/// only users on this list (plus permanent user-assignments) may book it.
model AssetAllowList {
  assetId   String
  userId    String
  createdAt DateTime @default(now())
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([assetId, userId])
}

/// Category for an asset. Controls default bookability and map appearance.
model AssetCategory {
  id               String   @id @default(cuid())
  name             String   @unique
  description      String?
  /// New assets in this category are bookable by default when true.
  defaultIsBookable Boolean @default(false)
  /// Icon slug used on the floor-plan canvas (e.g. "monitor", "phone", "lock").
  defaultIcon      String?
  /// Hex colour for map markers in this category.
  colour           String   @default("#6366f1")
  createdAt        DateTime @default(now())
  assets           Asset[]
}

/// Unified asset model. Bookable assets (isBookable=true) replace the old Desk model.
/// Non-bookable assets are physical inventory items tracked for assignment purposes.
model Asset {
  id           String      @id @default(cuid())
  categoryId   String
  name         String
  description  String?
  serialNumber String?
  assetTag     String?     @unique
  /// Physical tracking status.
  status       AssetStatus @default(AVAILABLE)
  notes        String?

  // ── Bookability ────────────────────────────────────────────────────────────
  /// When true, users can book this asset on the floor plan.
  isBookable    Boolean        @default(false)
  /// Label shown in the booking UI, e.g. "Desk", "Phone Booth", "Room".
  bookingLabel  String?
  /// Amenities available on this asset (only meaningful when isBookable=true).
  amenities     String[]
  /// Booking eligibility. Null when not bookable.
  bookingStatus BookableStatus?

  // ── Map placement ──────────────────────────────────────────────────────────
  /// Primary zone this asset belongs to (null = not placed on any floor plan).
  primaryZoneId String?
  /// Floor this asset is placed on (null = not placed).
  floorId       String?
  x             Float?
  y             Float?
  /// Rendered width on the canvas (grid units). Defaults to 3 for placed assets.
  width         Float?
  /// Rendered height on the canvas (grid units). Defaults to 2 for placed assets.
  height        Float?
  rotation      Float?

  // ── Physical asset tracking ────────────────────────────────────────────────
  purchaseDate   DateTime?
  warrantyExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category        AssetCategory         @relation(fields: [categoryId], references: [id])
  primaryZone     Zone?                 @relation("PrimaryZone", fields: [primaryZoneId], references: [id], onDelete: SetNull)
  floor           Floor?                @relation(fields: [floorId], references: [id], onDelete: SetNull)
  additionalZones AssetZone[]
  allowList       AssetAllowList[]
  userAssignments       AssetUserAssignment[]
  availabilityWindows   AssetAvailabilityWindow[]
  /// Temporary assignments (checked-out to a user with a return date).
  assignments     AssetAssignment[]
  /// Bookings made against this asset (only populated when isBookable=true).
  bookings        Booking[]
  queueEntries    QueueEntry[]

  @@index([floorId])
  @@index([primaryZoneId])
  @@index([categoryId])
  @@index([isBookable])
}

/// Availability window: a permanently assigned user can offer their asset for
/// temporary booking by others during a specific time range.
model AssetAvailabilityWindow {
  id        String   @id @default(cuid())
  assetId   String
  ownerId   String
  startsAt  DateTime
  endsAt    DateTime
  note      String?
  createdAt DateTime @default(now())
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  owner     User     @relation("AvailabilityWindowOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([assetId, startsAt, endsAt])
  @@index([ownerId])
}

/// Permanent user assignment — records which user "owns" or is primarily responsible
/// for an asset (e.g. a desk permanently assigned to an employee).
model AssetUserAssignment {
  assetId   String
  userId    String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([assetId, userId])
  @@index([assetId])
  @@index([userId])
}

/// Temporary assignment — tracks an asset checked out to a specific user
/// (e.g. a laptop loan). Has an explicit returnedAt to record when it was returned.
model AssetAssignment {
  id           String    @id @default(cuid())
  assetId      String
  userId       String?
  assignedById String?
  assignedAt   DateTime  @default(now())
  returnedAt   DateTime?
  notes        String?
  asset        Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user         User?     @relation(fields: [userId], references: [id])

  @@index([assetId])
  @@index([userId])
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  displayName   String
  passwordHash  String?
  provider      AuthProvider  @default(LOCAL)
  externalId    String?
  accountStatus AccountStatus @default(ACTIVE)
  globalRole    GlobalRole    @default(USER)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  resourceRoles        UserResourceRole[]
  bookings             Booking[]
  queueEntries         QueueEntry[]
  assetAssignments     AssetAssignment[]
  notifications        Notification[]
  auditLogsAsActor     AuditLog[]           @relation("actor")
  assetAllowList       AssetAllowList[]
  groupMemberships     UserGroupMember[]
  assetUserAssignments AssetUserAssignment[]
  availabilityWindows  AssetAvailabilityWindow[] @relation("AvailabilityWindowOwner")
  floorSubscriptions   FloorSubscription[]

  @@index([email])
  @@index([provider, externalId])
}

model UserGroup {
  id             String            @id @default(cuid())
  organisationId String
  name           String
  description    String?
  globalRole     GlobalRole        @default(USER)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  organisation   Organisation      @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  members        UserGroupMember[]
  buildingAccess GroupBuildingAccess[]
  floorAccess    GroupFloorAccess[]
  groupResourceRoles GroupResourceRole[]

  @@unique([organisationId, name])
  @@index([organisationId])
}

model UserGroupMember {
  groupId   String
  userId    String
  createdAt DateTime  @default(now())
  group     UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
}

model GroupBuildingAccess {
  groupId    String
  buildingId String
  createdAt  DateTime  @default(now())
  group      UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  building   Building  @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@id([groupId, buildingId])
}

model GroupFloorAccess {
  groupId   String
  floorId   String
  createdAt DateTime  @default(now())
  group     UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  floor     Floor     @relation(fields: [floorId], references: [id], onDelete: Cascade)

  @@id([groupId, floorId])
}

model UserResourceRole {
  id         String            @id @default(cuid())
  userId     String
  role       ResourceRoleType
  scopeType  ResourceScopeType
  buildingId String?
  floorId    String?
  createdAt  DateTime          @default(now())
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  building   Building?         @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floor      Floor?            @relation(fields: [floorId], references: [id], onDelete: Cascade)

  @@unique([userId, scopeType, buildingId, floorId])
  @@index([userId])
}

model GroupResourceRole {
  id         String            @id @default(cuid())
  groupId    String
  role       ResourceRoleType
  scopeType  ResourceScopeType
  buildingId String?
  floorId    String?
  createdAt  DateTime          @default(now())
  group      UserGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  building   Building?         @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  floor      Floor?            @relation(fields: [floorId], references: [id], onDelete: Cascade)

  @@unique([groupId, scopeType, buildingId, floorId])
  @@index([groupId])
}

model Booking {
  id        String        @id @default(cuid())
  userId    String
  assetId   String
  startsAt  DateTime
  endsAt    DateTime
  status    BookingStatus @default(CONFIRMED)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset     Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, startsAt, endsAt])
  @@index([userId, startsAt])
  @@index([status])
}

model QueueEntry {
  id             String           @id @default(cuid())
  userId         String
  assetId        String
  wantedStartsAt DateTime
  wantedEndsAt   DateTime
  position       Int
  status         QueueEntryStatus @default(WAITING)
  expiresAt      DateTime
  claimDeadline  DateTime?
  claimToken     String?          @unique
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset          Asset            @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, status, wantedStartsAt, wantedEndsAt])
  @@index([userId, status])
  @@index([expiresAt, status])
  @@index([claimToken])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  metadata  Json             @default("{}")
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String
  action       String
  resourceType String
  resourceId   String
  before       Json?
  after        Json?
  ipAddress    String?
  createdAt    DateTime @default(now())
  actor        User     @relation("actor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
}

/// JWT revocation blocklist.
/// A row is inserted on logout. requireAuth checks this table after signature
/// verification so that logged-out tokens cannot be replayed before their exp.
/// Rows are pruned by pruneExpiredBlocklistEntries() once the JWT has expired.
/// Singleton config for SCIM 2.0 outbound provisioning.
/// Entra ID / Okta authenticates to the SCIM endpoint with a bearer token
/// whose SHA-256 hash is stored here. Generate via Admin → Settings → SCIM.
model ScimConfig {
  id        String   @id @default(cuid())
  enabled   Boolean  @default(false)
  /// SHA-256 hex of the bearer token. Never store the plaintext.
  tokenHash String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FloorSubscription {
  id             String    @id @default(cuid())
  userId         String
  floorId        String
  lastNotifiedAt DateTime?
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  floor          Floor     @relation(fields: [floorId], references: [id], onDelete: Cascade)
  zones          FloorSubscriptionZone[]

  @@unique([userId, floorId])
  @@index([userId])
  @@index([floorId])
}

model FloorSubscriptionZone {
  subscriptionId String
  zoneId         String
  subscription   FloorSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  zone           Zone              @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@id([subscriptionId, zoneId])
  @@index([zoneId])
}

model RevokedToken {
  /// The jti claim from the JWT — a UUID assigned at sign time.
  jti       String   @id
  /// Unix epoch at which the original JWT expires. Used for pruning only;
  /// the blocklist check ignores this field (the JWT exp check already handles expiry).
  expiresAt DateTime

  @@index([expiresAt])
}
